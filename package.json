{
  "name": "ludwig-chess",
  "module": "shared/chess.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run server/index.ts",
    "dev": "bun run --hot server/index.ts",
    "test": "bun test tests/",
    "build": "bun --cwd=frontend run build",
    "format": "bun x prettier --write .",
    "format:check": "bun x prettier --check .",
    "lint": "bun x eslint .",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json && bun --cwd=frontend x tsc --noEmit",
    "ci": "bun x prettier --check . && bun x eslint . && bun run typecheck && bun test tests/ && bun run build",
    "gate:e2e": "bun run build && bun tests/e2e/gate.mjs",
    "gate:docker": "bun scripts/gate-docker.mjs",
    "gate:prod": "bun scripts/gate-prod.mjs",
    "smoke:live": "bun scripts/smoke-live.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "latest",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "playwright-core": "^1.61.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.48.0"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "hono": "^4.12.23",
    "nanoid": "^5.1.11"
  }
}
